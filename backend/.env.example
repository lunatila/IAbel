# LLM Provider Configuration
# Escolha qual provedor usar: "ollama", "openai", "gemini"
LLM_PROVIDER=gemini

# Google Gemini API Key (recomendado)
GOOGLE_API_KEY=your_google_api_key_here
# Modelo Gemini: gemini-2.0-flash-exp, gemini-1.5-pro, gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash-exp

# OpenAI API Key (alternativa)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4

# Anthropic API Key (alternativa)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (local - sem API key necessária)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:3b

# Database URL (if using SQLAlchemy)
DATABASE_URL=sqlite:///./data/isabel.db

# CORS origins
CORS_ORIGINS=["http://localhost:3000"]
